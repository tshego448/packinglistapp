<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#F5F5F5">

    <!-- App Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✈ Travel Packing Manager"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Keep your travel organised"
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_marginBottom="32dp"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#BBDEFB"
        android:layout_marginBottom="32dp"/>

    <!-- Add to Packing List Button -->
    <Button
        android:id="@+id/btnAddItem"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="➕  Add to Packing List"
        android:textSize="16sp"
        android:backgroundTint="#1976D2"
        android:layout_marginBottom="16dp"/>

    <!-- View Packing List Button -->
    <Button
        android:id="@+id/btnViewList"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📋  View Packing List"
        android:textSize="16sp"
        android:backgroundTint="#388E3C"
        android:layout_marginBottom="16dp"/>

    <!-- Exit Button -->
    <Button
        android:id="@+id/btnExit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🚪  Exit App"
        android:textSize="16sp"
        android:backgroundTint="#D32F2F"/>

</LinearLayout>
